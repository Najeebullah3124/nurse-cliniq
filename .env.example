# OpenAI API key for AI-generated quiz questions (Admin > Quizzes > Generate with AI)
OPENAI_API_KEY=sk-your-openai-api-key-here

# Optional: JWT secret for production
# JWT_SECRET=your-random-secret

# Optional: Port (default 3000)
# PORT=3000

# Server bind (default 0.0.0.0 so EC2/VPS accepts external traffic)
# HOST=0.0.0.0

# Optional: shown in startup logs; use your instance public IPv4 (e.g. AWS EC2)
# PUBLIC_HOST=16.16.253.8

# Optional: full public URL if behind HTTPS reverse proxy
# PUBLIC_URL=https://your-domain.com
